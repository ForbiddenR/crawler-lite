# Caddy production config.
#
# {$DOMAIN} is expanded from the environment at startup. Two modes:
#
#   DOMAIN=crawler.example.com  → Caddy obtains + renews a Let's Encrypt
#                                 cert automatically, serves :80 (redirect)
#                                 and :443 (TLS).
#   DOMAIN=:80                  → plain HTTP, no TLS (local/staging).
#
# The master serves everything (REST, WebSocket, SPA) on :8000; Caddy is
# only TLS termination + reverse proxy. gRPC (:9000) is internal to the
# compose network and not proxied here.
{
	email {$ACME_EMAIL:-}
}

{$DOMAIN} {
	encode gzip zstd

	log {
		output stdout
		format json
	}

	# flush_interval -1 enables immediate flushing so streamed responses
	# (WebSocket log tail, SSE) reach the browser without buffering.
	reverse_proxy master:8000 {
		flush_interval -1
	}
}
