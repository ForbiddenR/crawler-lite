# Master
HTTP_ADDR=:8000
GRPC_ADDR=:9000

DATABASE_DSN=postgres://crawler:crawler@localhost:5432/crawler?sslmode=disable

REDIS_ADDR=localhost:6379

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=crawler
MINIO_SECRET_KEY=crawler-secret
MINIO_BUCKET=crawler-artifacts
MINIO_SECURE=false

JWT_SECRET=dev-change-me-please-32+chars-required
JWT_TTL=24h

WORKER_SHARED_SECRET=dev-worker-secret

BCRYPT_COST=10

# Worker
MASTER_GRPC_ADDR=localhost:9000
WORKER_ID=worker-local-1
WORKER_CONCURRENCY=4
PYTHON_PATH=python3
WORKER_WORKDIR=/tmp/crawler-lite
# For local runs point this at a writable dir (the default /var/lib needs root):
#   WORKER_VENV_DIR=/tmp/crawler-lite/venvs
WORKER_VENV_DIR=/var/lib/crawler-lite/venvs
# UV_PATH=                      # leave empty to auto-detect uv on PATH
# Local path to the crawlerkit SDK source. crawlerkit is NOT on PyPI, so the
# worker installs it from disk into each per-spider venv. Default /opt/crawlerkit-py
# is where the worker Docker image bundles it; for local runs point at the repo:
#   WORKER_CRAWLERKIT_PATH=./crawlerkit-py
WORKER_CRAWLERKIT_PATH=/opt/crawlerkit-py
WORKER_CAPABILITIES=python3.12
