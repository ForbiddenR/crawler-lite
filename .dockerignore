# Build artifacts
/bin/
/web/dist/
/web/.vite/

# Frontend deps — installed inside the frontend-build stage
/web/node_modules/

# Env / secrets — never bake into an image
.env
.env.*
!.env.example
!.env.prod.example

# VCS / editor / OS
.git/
.gitignore
.idea/
.vscode/
.DS_Store
*.swp

# Go test/build cruft
*.log
*.out
coverage.*

# Agent / planning scratch (not part of the shipped image)
.claude/
loadtest/results/
backups/

# Generated protobuf lives in-tree and IS needed at build time, so do
# NOT exclude internal/pb/.
