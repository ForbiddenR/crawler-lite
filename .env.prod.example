# =============================================================================
# crawler-lite production environment.
# Copy to `.env` and edit before `make prod-up`. Every secret below is a
# placeholder — rotate ALL of them.
# =============================================================================

# --- Image / deployment -----------------------------------------------------
# Where the built images live. For a private registry use e.g.
# ghcr.io/your-org; for a local build leave as `crawler-lite` (images built
# by `make prod-build` are tagged locally).
IMAGE_REGISTRY=crawler-lite
# Pinned at image build time; also selects which image tag to run. Use a
# git tag for releases (v0.1.0) or a commit SHA for staging.
VERSION=dev
# Reverse proxy / TLS are managed outside this project by the host/server
# infrastructure. Point your Nginx/Caddy upstream at http://127.0.0.1:8000.

# --- Postgres ---------------------------------------------------------------
# These override the dev defaults baked into docker-compose.yml.
POSTGRES_USER=crawler
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=crawler
# As consumed by the master via DATABASE_DSN. The host is the compose
# service name `postgres`.
DATABASE_DSN=postgres://crawler:CHANGE_ME_strong_password@postgres:5432/crawler?sslmode=disable
DB_POOL_SIZE=20

# --- Redis ------------------------------------------------------------------
# Ephemeral cache only — NOT backed up. Host is the compose service `redis`.
REDIS_ADDR=redis:6379

# --- MinIO ------------------------------------------------------------------
MINIO_ROOT_USER=crawler
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_secret
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=crawler
MINIO_SECRET_KEY=CHANGE_ME_strong_secret
MINIO_BUCKET=crawler-artifacts
MINIO_SECURE=false

# --- Master -----------------------------------------------------------------
# HTTP is published to 127.0.0.1:8000 by docker-compose.prod.yml for the
# host-managed reverse proxy. gRPC stays inside the compose network.
HTTP_ADDR=:8000
GRPC_ADDR=:9000

# --- Master auth ------------------------------------------------------------
# JWT_SECRET must be >= 32 chars. Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32
JWT_TTL=24h
BCRYPT_COST=12

# --- Worker ↔ master gRPC ---------------------------------------------------
# Shared secret for worker auth on the gRPC stream. Must match on every
# worker. Generate with: openssl rand -hex 32
WORKER_SHARED_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# --- Worker config ----------------------------------------------------------
# Leave WORKER_ID unset — the worker falls back to its container hostname so
# `docker compose up --scale worker=N` works without per-replica config.
# WORKER_ID=
MASTER_GRPC_ADDR=master:9000
WORKER_CONCURRENCY=4
PYTHON_PATH=python3
WORKER_WORKDIR=/tmp/crawler-lite
WORKER_VENV_DIR=/var/lib/crawler-lite/venvs
UV_PATH=uv
WORKER_CRAWLERKIT_PATH=/opt/crawlerkit-py
WORKER_CAPABILITIES=python3.12,chromium,selenium
